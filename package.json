{
  "name": "mcp-coffee",
  "version": "1.0.0",
  "description": "Учебный проект: MCP-сервер кофейни + Telegram-бот с ручной петлёй tool-use на OpenAI",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:bot": "tsx watch src/bot.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "start:bot": "node dist/bot.js",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "openai": "^4.77.0",
    "telegraf": "^4.16.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
